# LLM Provider (openrouter, nvidia, openai)
LLM_PROVIDER=openrouter

# API key for the LLM provider
LLM_API_KEY=your-api-key-here

# Model to use (default: nvidia/nemotron-3-super-120b-a12b)
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b

# Custom base URL (overrides provider URL, for local servers or custom endpoints)
# LLM_BASE_URL=http://localhost:8000/v1

# Temperature for LLM responses (0.0 to 1.0, lower = more consistent)
LLM_TEMPERATURE=0.1

# Top-p (nucleus sampling) for LLM responses (0.0 to 1.0)
# LLM_TOP_P=0.95

# Maximum tokens in LLM response (128+, default 4096)
# LLM_MAX_TOKENS=4096

# Request timeout in seconds for LLM API calls
REQUEST_TIMEOUT_SECONDS=120

# Token budget tier (free, standard, premium)
# - free: 5000 tokens (8k context models, free tier APIs)
# - standard: 16000 tokens (32k context models)
# - premium: 48000 tokens (128k context models)
# Budget is auto-detected from model name when possible. Tier is the fallback.
TOKEN_TIER=free

# Explicit token budget override (overrides both tier and auto-detection)
# MAX_PROMPT_TOKENS=32000

# Maximum total tokens per review (all agents + synthesis). Optional hard cap.
# When exceeded, a warning is logged. Default: unlimited.
# MAX_TOKENS_PER_REVIEW=50000

# Custom LLM pricing (per 1M tokens). Overrides auto-detected pricing.
# Used for cost estimation in the report. Leave unset for auto-detection.
# LLM_INPUT_PRICE_PER_M=0.30
# LLM_OUTPUT_PRICE_PER_M=0.60

# Rate limit: requests per minute (auto-detected from tier by default)
# FREE=5 rpm, STANDARD=30 rpm, PREMIUM=unlimited
# Adapts automatically from provider 429 responses.
# RATE_LIMIT_RPM=10

# Maximum total review time in seconds (all agents + synthesis)
MAX_REVIEW_SECONDS=600

# Deduplication strategy for findings across agents
# exact (default): same file + line + title
# location: same file + line only
# similar: same file + line + title similarity > 0.6
# disabled: no dedup
DEDUP_STRATEGY=exact

# Maximum number of files to fetch from a GitHub PR (pagination cap)
MAX_PR_FILES=200

# GitHub personal access token (for PR integration)
GITHUB_TOKEN=your-github-token-here

# GitHub API base URL (override for testing with mock server)
# GITHUB_API_BASE_URL=http://localhost:9998

# GitHub rate limit warning threshold (log WARNING when remaining < this)
# Unauthenticated: 60/hour, Authenticated: 5000/hour
# GITHUB_RATE_LIMIT_WARN_THRESHOLD=100

# Days of inactivity before a PR is considered stale (for `pr stale` command)
# PR_STALE_DAYS=7

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Maximum number of agents running in parallel
MAX_CONCURRENT_AGENTS=4

# Interactive mode settings
# INTERACTIVE_HISTORY_FILE=~/.cra_history
# INTERACTIVE_PROMPT=cra>
# INTERACTIVE_VI_MODE=false
# INTERACTIVE_AUTOCOMPLETE_CACHE_TTL=5

# Watch mode: polling interval in seconds (for `watch` command)
# WATCH_DEBOUNCE_SECONDS=5.0

# Iterative review: run agents multiple rounds for deeper analysis
# Each round feeds previous findings back to agents. Cost multiplier = N rounds.
# MAX_DEEPENING_ROUNDS=1

# Validation: separate validator agent reviews all findings for false positives
# Adds 1 LLM call per validation round. Only useful with 2+ review agents.
# IS_VALIDATION_ENABLED=false
# MAX_VALIDATION_ROUNDS=1

# Custom agents: directory containing YAML agent definitions
# Agents are also loaded from .cra/agents/ in the project root.
# CUSTOM_AGENTS_DIR=~/.cra/agents

# Default agents to run (comma-separated). Empty = use tier defaults.
# DEFAULT_AGENTS=security,performance

# Review history storage
# HISTORY_DB_PATH=~/.cra/reviews.db
# AUTO_SAVE_HISTORY=true

# Usage display window for toolbar and progress bar
# Options: session, hour, day, week, month, year, all
# USAGE_WINDOW=hour
