# LLM Provider (openrouter, nvidia, openai)
LLM_PROVIDER=openrouter

# API key for the LLM provider
LLM_API_KEY=your-api-key-here

# Model to use (default: nvidia/nemotron-3-super-120b-a12b)
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b

# Custom base URL (overrides provider URL, for local servers or custom endpoints)
# LLM_BASE_URL=http://localhost:8000/v1

# Temperature for LLM responses (0.0 to 1.0, lower = more consistent)
LLM_TEMPERATURE=0.1

# Request timeout in seconds for LLM API calls
REQUEST_TIMEOUT_SECONDS=120

# GitHub personal access token (for PR integration)
GITHUB_TOKEN=your-github-token-here

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Maximum number of agents running in parallel
MAX_CONCURRENT_AGENTS=4
