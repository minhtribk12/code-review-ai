# LLM Provider (openrouter, nvidia, openai)
LLM_PROVIDER=openrouter

# API key for the LLM provider
LLM_API_KEY=your-api-key-here

# Model to use (default: nvidia/nemotron-3-super-120b-a12b)
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b

# Custom base URL (overrides provider URL, for local servers or custom endpoints)
# LLM_BASE_URL=http://localhost:8000/v1

# Temperature for LLM responses (0.0 to 1.0, lower = more consistent)
LLM_TEMPERATURE=0.1

# Request timeout in seconds for LLM API calls
REQUEST_TIMEOUT_SECONDS=120

# Token budget tier (free, standard, premium)
# - free: 5000 tokens (8k context models, free tier APIs)
# - standard: 16000 tokens (32k context models)
# - premium: 48000 tokens (128k context models)
# Budget is auto-detected from model name when possible. Tier is the fallback.
TOKEN_TIER=free

# Explicit token budget override (overrides both tier and auto-detection)
# MAX_PROMPT_TOKENS=32000

# Rate limit: requests per minute (auto-detected from tier by default)
# FREE=5 rpm, STANDARD=30 rpm, PREMIUM=unlimited
# Adapts automatically from provider 429 responses.
# RATE_LIMIT_RPM=10

# Maximum total review time in seconds (all agents + synthesis)
MAX_REVIEW_SECONDS=300

# Deduplication strategy for findings across agents
# exact (default): same file + line + title
# location: same file + line only
# similar: same file + line + title similarity > 0.6
# disabled: no dedup
DEDUP_STRATEGY=exact

# GitHub personal access token (for PR integration)
GITHUB_TOKEN=your-github-token-here

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Maximum number of agents running in parallel
MAX_CONCURRENT_AGENTS=4
